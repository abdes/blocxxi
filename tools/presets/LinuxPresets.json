{
  "version": 6,
  "include": [
    "./BasePresets.json"
  ],
  "configurePresets": [
    {
      "name": "linux",
      "displayName": "Linux Default (Ninja)",
      "inherits": "default",
      "installDir": "${sourceDir}/out/install",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-asan",
      "displayName": "Linux ASAN (Ninja)",
      "inherits": "default-asan",
      "installDir": "${sourceDir}/out/install",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-debug",
      "inherits": "build-debug",
      "configurePreset": "linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-asan",
      "inherits": "build-asan",
      "configurePreset": "linux-asan",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-release",
      "inherits": "build-release",
      "configurePreset": "linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }
  ],
  "testPresets": [
    {
      "name": "test-linux-debug",
      "inherits": "test-debug",
      "configurePreset": "linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "test-linux-asan",
      "inherits": "test-asan",
      "configurePreset": "linux-asan",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "test-linux-release",
      "inherits": "test-release",
      "configurePreset": "linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }
  ]
}
